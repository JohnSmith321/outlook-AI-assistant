# ============================================================
# Outlook AI Assistant — Configuration
# ============================================================
# Copy this file to .env and fill in your settings.
#
# Choose ONE provider: "anthropic" or "openai"
# Default is "anthropic" if not set.
# ============================================================

AI_PROVIDER=anthropic

# --- Option A: Anthropic Claude (requires API key) ----------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-opus-4-6
# CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# --- Option B: OpenAI-compatible (Ollama, LM Studio, etc.) -
# AI_PROVIDER=openai
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:14b
# OPENAI_MODEL_FAST=qwen2.5:7b

# --- Examples for other providers ---------------------------
#
# OpenAI:
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o
#   OPENAI_MODEL_FAST=gpt-4o-mini
#
# LM Studio:
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=lm-studio
#   OPENAI_BASE_URL=http://localhost:1234/v1
#   OPENAI_MODEL=your-loaded-model
#
# OpenRouter (free models available):
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=sk-or-...
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=google/gemma-2-9b-it:free
#
# Groq (fast, free tier):
#   AI_PROVIDER=openai
#   OPENAI_API_KEY=gsk_...
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.1-70b-versatile
#   OPENAI_MODEL_FAST=llama-3.1-8b-instant

# --- General settings ---------------------------------------
# MAX_TOKENS=4096
